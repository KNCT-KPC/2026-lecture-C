{
  "name": "c-lecture",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:portal": "vite",
    "dev:day1": "slidev day1.md --open",
    "dev:day2": "slidev day2.md --open",
    "build:portal": "vite build",
    "build:day1": "slidev build day1.md --out dist/day1 --base /day1/",
    "build:day2": "slidev build day2.md --out dist/day2 --base /day2/",
    "build": "npm run build:portal && npm run build:day1 && npm run build:day2"
  },
  "keywords": [],
