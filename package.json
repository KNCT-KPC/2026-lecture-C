  "type": "commonjs",
  "dependencies": {
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "^0.25.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  }
}
